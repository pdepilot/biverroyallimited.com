<IfModule mod_rewrite.c>
    RewriteEngine On

    # Serve real files and folders directly (css, js, images, etc.)
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Extensionless URLs: /index -> index.php, /property -> property.php
    RewriteCond %{REQUEST_FILENAME}.php -f
    RewriteRule ^(.+?)/?$ $1.php [L]
</IfModule>
